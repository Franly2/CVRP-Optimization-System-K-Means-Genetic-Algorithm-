generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
//        DOMAIN Logistik
// ==========================================

enum PackageStatus {
  PENDING   // Belum diapa-apain (Masih di gudang)
  ASSIGNED  // Sudah masuk ke rute (hasil clustering)
  DELIVERED // Sudah sampai
  FAILED    // Gagal kirim
}

enum RouteStatus {
  ACTIVE    // Sedang jalan
  COMPLETED // Selesai
}

enum VehicleType {
  MOBIL 
  MOTOR 
}

model DriverLocation {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  lat         Float
  lng         Float
  lastUpdated DateTime @default(now())

  // NEW: Denormalisasi untuk RLS
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
}

model Vehicle {
  id          String @id @default(uuid())
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id])

  type        VehicleType @default(MOTOR)
  
  plateNumber String      
  model       String      // Honda Beat dsb

  maxWeight   Float // kg, buat constraint clustering
  maxVolume   Float // liter, buat constraint clustering

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])

  // plateNumber "B 1234 ABC" boleh sama di perusahaan berbeda, tapi harus unik di dalam perusahaan yang sama
  @@unique([plateNumber, companyId]) 
}

model Package {
  id            String @id @default(uuid())
  recipientName String
  address       String @db.Text

  companyId     String
  company       Company @relation(fields: [companyId], references: [id])
  depotId       String? // berangkat dari mana
  depot         Depot?  @relation(fields: [depotId], references: [id])

  lat           Float?
  lng           Float?

  weight        Float // (Product.weightEst * quantity) 
  volume        Float // (Product.volumeEst * quantity)
  status        PackageStatus @default(PENDING)

  routeId       String?
  route         Route?  @relation(fields: [routeId], references: [id])

  orderIndex    Int? // Urutan pengiriman hasil GA (0, 1, 2...)
  deliveryShiftId String
  deliveryShift DeliveryShift @relation(fields: [deliveryShiftId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  refOrderId    String? // kasus katering : ID dari tabel Order katering
  metadata      Json?   // kasus katering : nama menu katering dalam bentuk JSON
}

model Route {
  id          String @id @default(uuid())

  driverId    String
  driver      User   @relation(fields: [driverId], references: [id])

  companyId   String
  company     Company @relation(fields: [companyId], references: [id])
  depotId     String?
  depot       Depot?  @relation(fields: [depotId], references: [id])

  status      RouteStatus @default(ACTIVE)
  packages    Package[]

  totalDistance Float?  // Estimasi jarak total dari OSRM (km)
  totalWeight   Float?
  totalVolume   Float?
  polyline      String? @db.Text // Garis jalan raya dari OSRM buat digambar di Map
  colorCode     String? // Warna cluster (Hex code, misal "#FF0000")

  date          DateTime @default(now())
}

// ==========================================
//        DOMAIN Transaksi (Katering, Farmasi)
// ==========================================

enum Role {
  OWNER
  ADMIN
  DRIVER
  CUSTOMER 
}

enum AccountStatus {
  PENDING
  ACCEPTED
  REJECTED
  SUSPENDED 
}

model User {
  id          String   @id @default(uuid())
  username    String
  password    String
  fullName    String
  phoneNumber String
  birthDate   DateTime
  role        Role     @default(DRIVER)
  status      AccountStatus @default(PENDING)

  cartItems   CartItem[]

  orders         Order[]
  driverLocation DriverLocation?
  vehicle        Vehicle? // 1 Driver punya 1 Kendaraan
  routes         Route[]  // 1 Driver bisa punya histori banyak rute

  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  depotId       String?        // Opsional: Owner tidak punya depotId, Admin/Driver punya.
  depot         Depot?         @relation(fields: [depotId], references: [id])
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([username, companyId]) // username "budi" hanya boleh ada 1 di dalam company yang sama
}

enum ProductStatus {
  PENDING
  REJECTED
  AVAILABLE
  UNAVAILABLE
  DELETED
}

model Product {
  id             String          @id @default(uuid())
  name           String          // "Nasi Ayam" (Katering), "Paracetamol" (Farmasi)
  price          Int
  weightEst      Float
  volumeEst      Float
  isActive       Boolean         @default(true)
  isSubscription Boolean         @default(false)
  durationDays   Int?            // Misal: 30 (untuk langganan 30 hari)
  
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id])
  
  schedules      ProductSchedule[]
  images         ProductImage[]

  status          ProductStatus @default(PENDING)
  // Relasi ke keranjang belanja 
  items           OrderItem[]
  subscriptions   Subscription[]
  cartItems       CartItem[]
  availableShifts DeliveryShift[]
  availableAt Depot[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ProductImage {
  id        String  @id @default(uuid())
  url       String  // Tautan gambarnya (dari AWS S3/Cloudinary)
  isMain    Boolean @default(false) // Apakah ini foto cover depan?
  order     Int     @default(0) // Urutan foto (0, 1, 2, dst)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  // NEW: Denormalisasi untuk RLS
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
}

enum OrderStatus {
  UNPAID
  PAID
  PREPARING
  READY_FOR_DELIVERY
  COMPLETED
}

model Order {
  id              String @id @default(uuid())
  customerId      String
  customer        User   @relation(fields: [customerId], references: [id])

  companyId       String
  company         Company @relation(fields: [companyId], references: [id])
  depotId         String
  depot           Depot   @relation(fields: [depotId], references: [id])

  totalPrice      Int
  status          OrderStatus @default(UNPAID)

  // Titik tujuan yang diinput saat checkout
  deliveryAddress String @db.Text
  destLat         Float
  destLng         Float

  trackingId      String? // kasus catering : Menyimpan ID Package dari mesin Logistik (cth: "PKG-001")
  
  deliveryShiftId String
  deliveryShift   DeliveryShift @relation(fields: [deliveryShiftId], references: [id])

  items           OrderItem[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OrderItem {
  id         String @id @default(uuid())

  orderId    String
  order      Order  @relation(fields: [orderId], references: [id])

  productId  String
  product    Product @relation(fields: [productId], references: [id])

  quantity   Int
  priceAtBuy Int

  // NEW: Denormalisasi untuk RLS
  companyId  String
  company    Company @relation(fields: [companyId], references: [id])
}

model DeliveryShift {
  id        String  @id @default(uuid())
  name      String  // Misal: "Makan Siang", "Shift Pagi"
  startTime String  // Misal: "11:00"
  endTime   String  // Misal: "13:00"
  
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Relasi
  products  Product[] // Produk apa saja yang bisa dikirim di jam ini
  orders    Order[]
  packages  Package[]
}

enum SubStatus {
  ACTIVE
  PAUSED
  EXPIRED
}

model Subscription {
  id         String  @id @default(uuid())
  customerId String
  customer   User    @relation(fields: [customerId], references: [id])
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  companyId  String
  company    Company @relation(fields: [companyId], references: [id])

  startDate  DateTime  @default(now())
  endDate    DateTime  // Dihitung dari startDate + durationDays produk
  status     SubStatus @default(ACTIVE)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ProductSchedule {
  id          String  @id @default(uuid())
  productId   String
  product     Product @relation(fields: [productId], references: [id])

  dayOfWeek   Int     // Angka penanda hari: 1 = Senin, 2 = Selasa, ... 7 = Minggu
  menuDetails String  @db.Text // Isi menu hari itu, misal: "Nasi Putih, Ayam Goreng, Es Teh"

  // NEW: Denormalisasi untuk RLS
  companyId   String
  company     Company @relation(fields: [companyId], references: [id])

  @@unique([productId, dayOfWeek]) // Mencegah Admin gak sengaja bikin 2 jadwal untuk hari Senin di paket yang sama
}

model CartItem {
  id         String  @id @default(uuid())
  customerId String
  customer   User    @relation(fields: [customerId], references: [id])
  productId  String
  product    Product @relation(fields: [productId], references: [id])

  quantity   Int     @default(1)

  // NEW: Denormalisasi untuk RLS
  companyId  String
  company    Company @relation(fields: [companyId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([customerId, productId]) // Biar satu user gak punya 2 baris produk yang sama di keranjang
}

// ==========================================
//        DOMAIN Company (Katering, Farmasi)
// ==========================================
enum PlanTier {
  STARTER
  PRO
  ENTERPRISE
}

model Company {
  id              String  @id @default(uuid())
  slug            String  @unique // "katering-ibu-budi"
  name            String  // cth: "Katering Ibu Budi", "Apotek Sehat"
  industry        String? // cth: "F&B", "Healthcare", "Logistics"

  // --- UI/UX Branding ---
  logoUrl         String?
  colorPrimary    String? @default("#1976D2")
  colorSecondary  String? @default("#FFC107")

  // --- SaaS Limits & Tiering ---
  tier            PlanTier @default(STARTER)
  maxDepots       Int      @default(1)
  maxDrivers      Int      @default(3)
  maxOrdersPerDay Int      @default(50)

  // --- Relasi ke Domain Logistik ---
  depots           Depot[]
  users            User[]
  packages         Package[]
  routes           Route[]
  driverLocations  DriverLocation[]  // NEW
  vehicles         Vehicle[]         // NEW

  // --- Relasi ke Domain Katering ---
  products         Product[]
  orders           Order[]
  subscriptions    Subscription[]
  deliveryShifts   DeliveryShift[]
  productImages    ProductImage[]    // NEW
  orderItems       OrderItem[]       // NEW
  productSchedules ProductSchedule[] // NEW
  cartItems        CartItem[]        // NEW

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Depot {
  id        String @id @default(uuid())
  name      String //  "Gudang Utama Mulyosari"
  lat       Float
  lng       Float
  address   String @db.Text

  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  
  products Product[]
  users     User[]
  orders    Order[]   // list order yang berangkat dari depot ini (opsional, bisa juga diambil dari rute)
  packages  Package[] // biar Depot tahu paket apa saja yang berangkat dari sana
  routes    Route[]   // rute ini mulai dari depot mana
}