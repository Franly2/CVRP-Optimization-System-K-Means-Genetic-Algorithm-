generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum Role {
  DRIVER
  ADMIN
}

enum PackageStatus {
  PENDING     // Belum diapa-apain (Masih di gudang)
  ASSIGNED    // Sudah masuk ke rute (hasil clustering)
  DELIVERED   // Sudah sampai
  FAILED      // Gagal kirim
}

enum RouteStatus {
  ACTIVE      // Sedang jalan
  COMPLETED   // Selesai
}


model User {
  id             String          @id @default(uuid())
  username       String          @unique @db.VarChar(20)
  password       String
  fullName       String
  phoneNumber    String
  birthDate      DateTime
  role           Role            @default(DRIVER)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  maxCapacity  Int      @default(20)

  // Relasi ke tabel lain
  driverLocation DriverLocation?
  vehicle        Vehicle?        // 1 Driver punya 1 Kendaraan
  routes         Route[]         // 1 Driver bisa punya histori banyak rute
}

model DriverLocation {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  lat         Float
  lng         Float
  lastUpdated DateTime @default(now())
}

model Vehicle {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  
  plateNumber String   @unique
  model       String   // cth: "Honda Beat", "Grand Max"
  
  maxWeight   Float    // Kapasitas Berat (kg) -> Constraint algoritma
  maxVolume   Float    // Kapasitas Volume (liter) -> Constraint algoritma
}

model Package {
  id            String        @id @default(uuid())
  recipientName String
  address       String        @db.Text
  
  lat           Float?
  lng           Float?
  
  weight        Float         // Berat paket (kg)
  volume        Float         // Volume paket (liter)
  status        PackageStatus @default(PENDING)

  routeId       String?
  route         Route?        @relation(fields: [routeId], references: [id])
  
  orderIndex    Int?          // Urutan pengiriman hasil GA (0, 1, 2...)
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Route {
  id            String      @id @default(uuid())
  
  driverId      String
  driver        User        @relation(fields: [driverId], references: [id])
  
  status        RouteStatus @default(ACTIVE)
  packages      Package[]
  
  totalDistance Float?      // Estimasi jarak total dari OSRM (km)
  totalWeight   Float?      // NEW: Total berat paket dalam rute ini
  totalVolume   Float?      // NEW: Total volume paket dalam rute ini
  polyline      String?     @db.Text // NEW: Garis jalan raya dari OSRM buat digambar di Map
  colorCode     String?     // NEW: Warna cluster (Hex code, misal "#FF0000")
  
  date          DateTime    @default(now())
}